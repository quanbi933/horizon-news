{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek/deepseek-chat-v3-0324:free",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 3,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["en", "zh"]
  },
  "email": {
    "enabled": false
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      }
    ],
    "reddit": {
      "enabled": true,
      "fetch_comments": 3,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 12,
          "min_score": 100
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 12,
          "min_score": 100
        }
      ],
      "users": []
    },
    "telegram": {
      "enabled": false,
      "channels": [
        {
          "channel": "durov",
          "enabled": false,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10
    },
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python"],
      "keywords": [],
      "min_stars": 50,
      "max_items": 12
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "chat_id": "${TELEGRAM_CHAT_ID}",
      "text": "#{message_title}\n\n#{summary?limit=3500&split=---}"
    },
    "headers": ""
  }
}
