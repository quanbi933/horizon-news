{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "nvidia/nemotron-3-super-120b-a12b:free",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "analysis_concurrency": 3,
    "enrichment_concurrency": 2,
    "languages": ["zh"]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai"
      }
    ],
    "reddit": {
      "enabled": true,
      "fetch_comments": 0,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 6,
          "min_score": 150
        },
        {
          "subreddit": "CryptoCurrency",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 6,
          "min_score": 300
        }
      ],
      "users": []
    },
    "telegram": {
      "enabled": false
    },
    "twitter": {
      "enabled": false
    },
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All"],
      "keywords": ["llm", "ai", "agent", "crypto", "blockchain"],
      "min_stars": 80,
      "max_items": 8
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "chat_id": "${TELEGRAM_CHAT_ID}",
      "text": "#{message_title}\n\n#{summary?limit=3500&split=---}"
    },
    "headers": ""
  }
}
